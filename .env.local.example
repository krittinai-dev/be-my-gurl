# ── Supabase ─────────────────────────────────────────────
# หาได้จาก Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# service_role key (ฝั่ง server เท่านั้น ห้ามขึ้น NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── รหัสเข้าอัลบั้ม (ใส่แค่โค้ดนี้ ไม่ต้องมีอีเมล) ─────────
ALBUM_PASSWORD=27062026

# secret สำหรับเซ็น session cookie — สุ่มด้วย:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=random-long-hex-string
